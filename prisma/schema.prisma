generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id                String    @id @default(cuid())
  email             String?   @unique
  emailVerified     DateTime?
  name              String?
  image             String?
  role              String    @default("user")
  premium           Boolean   @default(false)
  anonymous         Boolean   @default(false)
  messageCount      Int       @default(0)
  dailyMessageCount Int       @default(0)
  dailyProMessageCount Int    @default(0)
  dailyReset        DateTime?
  dailyProReset     DateTime?
  favoriteModels    String[]  @default([])
  systemPrompt      String    @default("")
  preferences       Json      @default("{}")
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  lastActiveAt      DateTime?
  password          String?

  accounts      Account[]
  sessions      Session[]
  conversations Conversation[]
  projects      Project[]
  knowledgeBases KnowledgeBase[]
  notes         Note[]
  tasks         Task[]
  memories      Memory[]
  apiKeys       ApiKey[]
  integrations  Integration[]
  mcpServers    McpServer[]
}

model Conversation {
  id          String   @id @default(cuid())
  userId      String
  title       String   @default("New Chat")
  projectId   String?
  model       String?
  pinned      Boolean  @default(false)
  pinnedAt    DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project     Project? @relation(fields: [projectId], references: [id])
  messages    Message[]
  attachments Attachment[]
  knowledgeBases ChatKnowledgeBase[]
}

model Message {
  id              String   @id @default(cuid())
  conversationId  String
  role            String
  content         String   @default("")
  parts           Json?
  annotations     Json?
  attachments     Json?
  messageGroupId  String   @default("main")
  model           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  conversation    Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

model Attachment {
  id             String   @id @default(cuid())
  conversationId String
  userId         String
  projectId      String?
  storageKey     String
  fileName       String
  fileType       String
  fileSize       Int
  createdAt      DateTime @default(now())

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

model Project {
  id           String   @id @default(cuid())
  userId       String
  name         String
  instructions String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversations Conversation[]
}

model KnowledgeBase {
  id          String   @id @default(cuid())
  userId      String
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  files       KnowledgeFile[]
  chunks      KnowledgeChunk[]
  conversations ChatKnowledgeBase[]
}

model KnowledgeFile {
  id              String   @id @default(cuid())
  knowledgeBaseId String
  fileName        String
  filePath        String
  fileSize        Int
  fileType        String
  storageKey      String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  knowledgeBase   KnowledgeBase @relation(fields: [knowledgeBaseId], references: [id], onDelete: Cascade)
  chunks        KnowledgeChunk[]
}

model KnowledgeChunk {
  id              String   @id @default(cuid())
  knowledgeBaseId String
  knowledgeFileId String
  chunkText       String
  embedding       Unsupported("vector(1536)")?
  createdAt       DateTime @default(now())

  knowledgeBase   KnowledgeBase @relation(fields: [knowledgeBaseId], references: [id], onDelete: Cascade)
  knowledgeFile   KnowledgeFile @relation(fields: [knowledgeFileId], references: [id], onDelete: Cascade)
}

model ChatKnowledgeBase {
  id              String   @id @default(cuid())
  conversationId  String
  knowledgeBaseId String
  createdAt       DateTime @default(now())

  conversation    Conversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  knowledgeBase   KnowledgeBase @relation(fields: [knowledgeBaseId], references: [id], onDelete: Cascade)

  @@unique([conversationId, knowledgeBaseId])
}

model Note {
  id          String   @id @default(cuid())
  userId      String
  title       String
  content     String   @default("")
  isArchived  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Task {
  id          String   @id @default(cuid())
  userId      String
  title       String
  completed   Boolean  @default(false)
  priority    String?
  dueDate     DateTime?
  assignee    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Memory {
  id              String   @id @default(cuid())
  userId          String
  content         String
  category        String   @default("general")
  sourceChatId    String?
  isPinned        Boolean  @default(false)
  isAutoGenerated Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ApiKey {
  id           String   @id @default(cuid())
  userId       String
  provider     String
  encryptedKey String
  iv           String
  displayName  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
}

model Integration {
  id           String   @id @default(cuid())
  userId       String
  provider     String
  accessToken  String
  refreshToken String?
  expiresAt    DateTime?
  scopes       String?
  status       String   @default("active")
  email        String?
  metadata     Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model McpServer {
  id          String   @id @default(cuid())
  userId      String
  name        String
  description String?
  url         String
  transport   String   @default("sse")
  headers     Json?
  status      String   @default("unknown")
  enabled     Boolean  @default(true)
  tools       Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AppConfig {
  id                String   @id @default(cuid())
  key               String   @unique @default("default")
  systemPrompt      String   @default("")
  featureFlags      Json     @default("{}")
  marketingPageVariant String @default("default")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model ProviderConfig {
  id           String   @id @default(cuid())
  providerType String   @unique
  name         String
  apiEndpoint  String?
  apiKey       String?
  enabled      Boolean  @default(true)
  sortOrder    Int      @default(0)
  metadata     Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ModelConfig {
  id           String   @id @default(cuid())
  modelId      String   @unique
  provider     String
  displayName  String
  accessTier   String   @default("free")
  enabled      Boolean  @default(true)
  metadata     Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
