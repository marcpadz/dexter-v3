# Database
DATABASE_URL=postgres://user:password@host:5432/dbname

# Auth
# Generate a secret: openssl rand -hex 32
BETTER_AUTH_SECRET=your-secret-key-change-in-production
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# LLM API Keys (at least one required — all use provider/model-name format)
# Examples: anthropic/claude-sonnet-4-20250514, openai/gpt-4o, deepseek/deepseek-chat
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-proj-...
# OpenRouter — unified API for 300+ models (openrouter/anthropic/claude-sonnet-4)
OPENROUTER_API_KEY=sk-or-v1-...
# DeepSeek — deepseek/deepseek-chat, deepseek/deepseek-reasoner
DEEPSEEK_API_KEY=sk-...
# NVIDIA NIM — nvidia/llama-3.1-nemotron-70b-instruct, nvidia/mistral-large
NVIDIA_API_KEY=nvapi-...
# Z.AI / GLM — zai/glm-4-plus, zai/glm-4-flash (general: /api/paas/v4)
# Coding plan: zai-coding/glm-4-plus (uses /api/coding/paas/v4)
ZAI_API_KEY=
# Groq — groq/llama-3.3-70b-versatile, groq/mixtral-8x7b
GROQ_API_KEY=gsk_...
# Google Gemini — google/gemini-2.0-flash, google/gemini-2.0-pro
GOOGLE_GENERATIVE_AI_API_KEY=AIza...
# Mistral — mistral/mistral-large-latest, mistral/codestral
MISTRAL_API_KEY=

# Daytona Sandbox (required for code execution, files, browser)
DAYTONA_API_KEY=your-daytona-api-key
DAYTONA_API_URL=https://app.daytona.io/api
DAYTONA_TARGET=us

# Web Search (optional — Tavily API for agent web search)
TAVILY_API_KEY=
